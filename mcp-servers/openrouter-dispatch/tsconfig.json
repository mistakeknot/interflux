{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true
  },
  "include": [
    "index.ts",
    "dispatch-core.ts"
  ],
  "exclude": [
    "dispatch-core.test.ts",
    "dist",
    "node_modules"
  ]
}
