__pycache__/
*.pyc
.pytest_cache/
.env
.env.*
!.env.example

# Ephemeral verdict/review data
.clavain/verdicts/
.clavain/quality-gates/
.clavain/reviews/

# Flux-drive review outputs (may contain security findings — T4.1)
docs/research/flux-drive/

# Local workspace artifacts
.claude/
.clavain/

# FluxBench results (accumulates real scoring data — do not commit)
/data/

# MCP server build artifacts
/mcp-servers/*/dist/
/mcp-servers/*/node_modules/

# Stray .lock sidecars (e.g. config/flux-drive/model-registry.yaml.lock).
# These are zero-byte flock fd markers that should never be committed.
*.lock
# Keep lockfiles for supply chain safety — this negation MUST come after *.lock above.
!/mcp-servers/*/package-lock.json
