{
  "name": "interflux",
  "version": "0.2.70",
  "description": "Multi-agent review and research with scored triage, domain detection, content slicing, intermediate finding sharing, and knowledge injection. 17 agents (12 review + 5 research), 7 commands, 1 skill (unified flux-drive with review/research modes), 2 MCP servers (exa, openrouter-dispatch). Companion plugin for Clavain.",
  "author": {
    "name": "mistakeknot"
  },
  "license": "MIT",
  "keywords": [
    "review",
    "research",
    "multi-agent",
    "flux-drive",
    "flux-research",
    "domain-detection",
    "triage",
    "code-review",
    "document-review",
    "exa"
  ],
  "skills": [
    "./skills/flux-engine",
    "./skills/flux-review-engine"
  ],
  "commands": [
    "./commands/fetch-findings.md",
    "./commands/flux-agent.md",
    "./commands/flux-drive.md",
    "./commands/flux-explore.md",
    "./commands/flux-gen.md",
    "./commands/flux-research.md",
    "./commands/flux-review.md"
  ],
  "agents": [
    "./agents/research/best-practices-researcher.md",
    "./agents/research/framework-docs-researcher.md",
    "./agents/research/git-history-analyzer.md",
    "./agents/research/learnings-researcher.md",
    "./agents/research/repo-research-analyst.md",
    "./agents/review/fd-architecture.md",
    "./agents/review/fd-correctness.md",
    "./agents/review/fd-decisions.md",
    "./agents/review/fd-game-design.md",
    "./agents/review/fd-people.md",
    "./agents/review/fd-perception.md",
    "./agents/review/fd-performance.md",
    "./agents/review/fd-quality.md",
    "./agents/review/fd-resilience.md",
    "./agents/review/fd-safety.md",
    "./agents/review/fd-systems.md",
    "./agents/review/fd-user-product.md"
  ],
  "mcpServers": {
    "exa": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/launch-exa.sh",
      "args": [],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    },
    "openrouter-dispatch": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/launch-openrouter.sh",
      "args": [],
      "env": {
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
        "OPENROUTER_RATE_LIMIT": "20",
        "OPENROUTER_SPEND_CEILING_USD": "1.00"
      }
    }
  }
}
